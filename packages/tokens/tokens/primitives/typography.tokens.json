        "fontWeight": "500",
        "fontSize": "20px",
        "lineHeight": "28px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-xl — 1.25rem / 1.75rem"
    },
    "text-2xl": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "500",
        "fontSize": "24px",
        "lineHeight": "32px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-2xl — 1.5rem / 2rem"
    },
    "text-3xl": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "700",
        "fontSize": "30px",
        "lineHeight": "36px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-3xl — 1.875rem / 2.25rem"
    },
    "text-4xl": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "700",
        "fontSize": "36px",
