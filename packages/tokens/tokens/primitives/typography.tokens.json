{
  "$description": "Source: Typography scale uses Tailwind v3 type scale defaults (https://tailwindcss.com/docs/font-size) — no Figma file key was available to read from Figma MCP at time of authoring (2026-03-22). Font family tokens use Archivo (primary static font, D-07) and Inter Variable (variable font, D-08) as per project decisions. fontWeight defaults to 400 for body/small sizes (xs–lg) and 700 for display sizes (5xl–9xl). letterSpacing defaults to 0px where not specified. lineHeight uses Tailwind defaults (unitless 1 for display sizes text-5xl through text-9xl expressed as the equivalent px value). Per D-01 traceability requirement.",
  "font": {
    "family": {
      "default": {
        "$type": "fontFamily",
        "$value": ["Archivo", "sans-serif"],
        "$description": "Static font — separate @font-face per weight (400, 500, 700). @font-face declarations deferred to Phase 4."
      },
      "variable": {
        "$type": "fontFamily",
        "$value": ["Inter Variable", "Inter", "sans-serif"],
        "$description": "Variable font — single @font-face with font-weight: 100 900. @font-face declarations deferred to Phase 4."
      }
    }
  },
  "typography": {
    "$type": "typography",
    "text-xs": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "400",
        "fontSize": "12px",
        "lineHeight": "16px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-xs — 0.75rem / 1rem"
    },
    "text-sm": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "400",
        "fontSize": "14px",
        "lineHeight": "20px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-sm — 0.875rem / 1.25rem"
    },
    "text-base": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "400",
        "fontSize": "16px",
        "lineHeight": "24px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-base — 1rem / 1.5rem"
    },
    "text-lg": {
      "$value": {
        "fontFamily": "Archivo",
        "fontWeight": "400",
        "fontSize": "18px",
        "lineHeight": "28px",
        "letterSpacing": "0px"
      },
      "$description": "Tailwind text-lg — 1.125rem / 1.75rem"
    },
    "text-xl": {
      "$value": {
