{
  "elevation": {
    "$description": "Source: Shadow values use Tailwind v3 box-shadow defaults (none, sm, DEFAULT/md, lg, xl) — no Figma file key was available to read from Figma MCP at time of authoring (2026-03-22). DTCG standard names used: offsetX/offsetY (NOT x/y). Per D-01 traceability requirement.",
    "none": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(0, 0, 0, 0)",
        "offsetX": "0px",
        "offsetY": "0px",
        "blur": "0px",
        "spread": "0px"
      },
      "$description": "No shadow — transparent baseline elevation"
    },
    "sm": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(0, 0, 0, 0.05)",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      },
      "$description": "Tailwind shadow-sm"
    },
    "md": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0, 0, 0, 0.1)", "offsetX": "0px", "offsetY": "4px", "blur": "6px", "spread": "-1px" },
        { "color": "rgba(0, 0, 0, 0.06)", "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "-1px" }
      ],
      "$description": "Tailwind shadow (default medium)"
    },
    "lg": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0, 0, 0, 0.1)", "offsetX": "0px", "offsetY": "10px", "blur": "15px", "spread": "-3px" },
        { "color": "rgba(0, 0, 0, 0.05)", "offsetX": "0px", "offsetY": "4px", "blur": "6px", "spread": "-2px" }
      ],
      "$description": "Tailwind shadow-lg"
    },
    "xl": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0, 0, 0, 0.1)", "offsetX": "0px", "offsetY": "20px", "blur": "25px", "spread": "-5px" },
        { "color": "rgba(0, 0, 0, 0.04)", "offsetX": "0px", "offsetY": "8px", "blur": "10px", "spread": "-6px" }
      ],
      "$description": "Tailwind shadow-xl"
    }
  }
}
